rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.role == "admin" ||
        request.auth.token.role == "super_admin" ||
        request.auth.token.role == "transport_admin"
      );
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /userPreferences/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /routes/{routeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /schedules/{scheduleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /liveBuses/{busId} {
      allow read: if isSignedIn();
      // Drivers and admins may publish GPS; students read-only.
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /chatRooms/{roomId} {
      allow read: if isSignedIn() && (roomId == request.auth.uid || isAdmin());
      allow create, update: if isSignedIn() && (roomId == request.auth.uid || isAdmin());

      match /messages/{messageId} {
        allow read: if isSignedIn() && (roomId == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && roomId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    match /subscriptions/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      match /invoices/{invoiceId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) || isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /offers/{offerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /auditEvents/{eventId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
