rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.get('role', '') in ['admin', 'super_admin', 'transport_admin'];
    }

    match /chat-attachments/{uid}/{allPaths=**} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    match /admin/{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
